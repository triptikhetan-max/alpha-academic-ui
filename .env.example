# Copy to .env.local for local dev. In Vercel, set these in Project → Settings → Environment Variables.

# Auth.js / NextAuth
AUTH_SECRET=                  # generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=             # from Google Cloud Console
GOOGLE_CLIENT_SECRET=         # from Google Cloud Console

# alpha-academic-api (the existing FastAPI)
ALPHA_API_URL=https://alpha-academic-api.vercel.app
ALPHA_API_KEY=                # one of the keys in your Notes (use the dedicated UI key)
