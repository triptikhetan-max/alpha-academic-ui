# Copy to .env.local for local dev. In Vercel, set these in Project → Settings → Environment Variables.

# Auth.js / NextAuth
AUTH_SECRET=                  # generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=             # from Google Cloud Console
GOOGLE_CLIENT_SECRET=         # from Google Cloud Console

# alpha-academic-api (the existing FastAPI)
ALPHA_API_URL=https://alpha-academic-api.vercel.app
ALPHA_API_KEY=                # one of the keys in your Notes (use the dedicated UI key)

# ── Brain Dashboard ────────────────────────────────────────────────
# GMAIL_USER and GMAIL_APP_PASSWORD are reused from the request-plugin
# email path; only declare them once. ADMIN_CC is reused as well.
GMAIL_USER=                    # tripti.khetan@trilogy.com
GMAIL_APP_PASSWORD=            # Gmail app-specific password (16 char)
ADMIN_CC=                      # tripti.khetan@trilogy.com (BCC'd on dashboard emails)
DASHBOARD_ORIGIN=https://alpha-academic-ui.vercel.app
CRON_SECRET=                   # generate with: openssl rand -base64 32

# ── Live Timeback analytics (optional) ─────────────────────────────
# Optional — enables /api/dashboard/live-activity for fresh-as-of-now XP data.
# Same Cognito M2M creds Tripti's local pullers use.
# When unset, the live-activity endpoint returns 503 and the dashboard
# falls back to the cached `dd.live_activity` from the nightly data.json.
ALPHA_CLIENT_ID=
ALPHA_CLIENT_SECRET=
